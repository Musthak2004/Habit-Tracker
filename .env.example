# ── Supabase ─────────────────────────────────────────────────
# Create your project at https://supabase.com then fill these in.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── AI Provider — RECOMMENDED: Server-side proxy ────────────
# Deploy the Edge Function first (see supabase/functions/ai-proxy/)
# then set this URL. The AI API key lives ONLY on the server.
# EXPO_PUBLIC_AI_PROXY_URL=https://your-project.supabase.co/functions/v1/ai-proxy

# ── AI Provider — LEGACY: Direct client call (dev only) ────
# ⚠️  EXPO_PUBLIC_ AI keys are bundled into the client app!
#     Anyone who extracts your APK/IPA can make AI calls at
#     your expense. Use the proxy URL above for production.
#
# For Anthropic Claude (default):
# EXPO_PUBLIC_AI_API_KEY=sk-ant-your-claude-api-key
# EXPO_PUBLIC_AI_MODEL=claude-sonnet-4-20250514
#
# For DeepSeek (alternative):
# EXPO_PUBLIC_AI_API_URL=https://api.deepseek.com/v1
# EXPO_PUBLIC_AI_API_KEY=sk-your-deepseek-key
# EXPO_PUBLIC_AI_MODEL=deepseek-chat
#
# For any OpenAI-compatible endpoint:
# EXPO_PUBLIC_AI_API_URL=https://api.openai.com/v1
# EXPO_PUBLIC_AI_API_KEY=sk-your-openai-key
# EXPO_PUBLIC_AI_MODEL=gpt-4o
